# Cloudflare credentials (required)
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ACCOUNT_EMAIL=

# Maximum number of domains to push to Cloudflare Gateway.
# Use 300000 for the Zero Trust free plan, or your plan's actual limit.
CLOUDFLARE_LIST_ITEM_LIMIT=300000

# Set to 1 to print what would happen without calling the Cloudflare API
DRY_RUN=0

# Set to 1 to create/delete lists with several requests in flight at once
# (bounded by CONCURRENCY) instead of one at a time
FAST_MODE=0

# Max simultaneous Cloudflare API requests when FAST_MODE=1
CONCURRENCY=5

# Optional: override the default allow/block list sources, one URL per line
# ALLOWLIST_URLS=
# BLOCKLIST_URLS=

# Optional: URL to curl after a successful sync, for monitoring
# PING_URL=
